# Provider for the VLM client (openai-compatible endpoint)
VLM_PROVIDER=groq
VLM_MODEL_NAME=meta-llama/llama-4-scout-17b-16e-instruct
VLM_BASE_URL=https://api.groq.com/openai/v1
VLM_API_KEY=your_key_here

# MLflow tracking (defaults to local ./mlruns if unset)
MLFLOW_TRACKING_URI=

# Swap to a local vLLM server for the self-hosted comparison, e.g.:
# VLM_PROVIDER=vllm-local
# VLM_MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct
# VLM_BASE_URL=http://localhost:8001/v1
# VLM_API_KEY=not-needed
